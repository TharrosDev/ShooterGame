[gd_resource type="Resource" script_class="QuestResource" load_steps=6 format=3]

[ext_resource type="Script" path="res://src/Quests/QuestResource.cs" id="1_quest"]
[ext_resource type="Script" path="res://src/Quests/ObjectiveResource.cs" id="2_obj"]
[ext_resource type="Script" path="res://src/Quests/QuestItemReward.cs" id="3_reward"]

[sub_resource type="Resource" id="Obj_example"]
script = ExtResource("2_obj")
Type = 0
TargetId = "enemy.goblin"
RequiredCount = 3
Description = "Slay goblins"

[sub_resource type="Resource" id="Reward_example"]
script = ExtResource("3_reward")
ItemId = "item.potion.health"
Quantity = 1

[resource]
script = ExtResource("1_quest")
Id = "quest.example"
Title = "Example Quest"
Summary = "One or two sentences framing the quest for the journal."
Objectives = Array[Resource]([SubResource("Obj_example")])
XpReward = 75
GoldReward = 20
GoldItemId = "item.currency.gold"
RewardItems = Array[Resource]([SubResource("Reward_example")])
PrerequisiteQuestId = ""

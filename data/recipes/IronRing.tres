[gd_resource type="Resource" script_class="CraftingRecipeResource" load_steps=5 format=3 uid="uid://cmbrvlrcpring"]

[ext_resource type="Script" path="res://src/Crafting/CraftingRecipeResource.cs" id="1_recipe"]
[ext_resource type="Script" path="res://src/Crafting/RecipeIngredient.cs" id="2_ing"]

[sub_resource type="Resource" id="Ing_ingot"]
script = ExtResource("2_ing")

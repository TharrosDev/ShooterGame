[gd_resource type="Resource" script_class="DialogueResource" load_steps=40 format=3 uid="uid://cmbrvldlgeldr"]

[ext_resource type="Script" path="res://src/Dialogue/DialogueResource.cs" id="1_dlg"]
[ext_resource type="Script" path="res://src/Dialogue/DialogueNode.cs" id="2_node"]
[ext_resource type="Script" path="res://src/Dialogue/DialogueChoice.cs" id="3_choice"]

[sub_resource type="Resource" id="ch_root_friend"]
script = ExtResource("3_choice")
Text = "(Greet the elder like an old friend.)"
Goto = "friend"
Condition = 5
ConditionArg = "flag.elder_thanked"

[sub_resource type="Resource" id="ch_root_thanks"]
script = ExtResource("3_choice")
Text = "About that iron I gathered..."
Goto = "thanks"
Condition = 3
ConditionArg = "quest.gather_iron"

[sub_resource type="Resource" id="ch_root_offer"]
script = ExtResource("3_choice")
Text = "What do you need?"
Goto = "offer"
Condition = 1
ConditionArg = "quest.gather_iron"

[sub_resource type="Resource" id="ch_root_active"]
script = ExtResource("3_choice")
Text = "I'm still searching for that iron."
Goto = "inprogress"
Condition = 2
ConditionArg = "quest.gather_iron"

[sub_resource type="Resource" id="ch_root_bye"]
script = ExtResource("3_choice")
Text = "Farewell."

[sub_resource type="Resource" id="ch_offer_accept"]
script = ExtResource("3_choice")
Text = "I'll fetch your iron."
Goto = "accepted"
Effect = 1
EffectArg = "quest.gather_iron"

[sub_resource type="Resource" id="ch_offer_decline"]
script = ExtResource("3_choice")
Text = "Not just now."

[sub_resource type="Resource" id="ch_accepted_bye"]
script = ExtResource("3_choice")
Text = "I'll head north."

[sub_resource type="Resource" id="ch_inprogress_bye"]
script = ExtResource("3_choice")
Text = "I'll keep looking."

[sub_resource type="Resource" id="ch_thanks_done"]
script = ExtResource("3_choice")
Text = "Glad to help."
Effect = 2
EffectArg = "flag.elder_thanked"

[sub_resource type="Resource" id="ch_friend_bye"]
script = ExtResource("3_choice")
Text = "Be well, elder."

[sub_resource type="Resource" id="ch_root_pure"]
script = ExtResource("3_choice")
Text = "(Clasp his hand — your heart is still your own.)"
Goto = "pure"
Condition = 8
ConditionArg = "30"

[sub_resource type="Resource" id="ch_root_marked"]
script = ExtResource("3_choice")
Text = "(He flinches at your gaze. Ask what troubles him.)"
Goto = "marked"
Condition = 7
ConditionArg = "30"

[sub_resource type="Resource" id="ch_pure_bye"]
script = ExtResource("3_choice")
Text = "The Flame keeps us both, elder."

[sub_resource type="Resource" id="ch_marked_embrace"]
script = ExtResource("3_choice")
Text = "(Say nothing. Let the ember within stir.)"
Effect = 4
EffectArg = "10"

[sub_resource type="Resource" id="ch_marked_deny"]
script = ExtResource("3_choice")
Text = "It is nothing, elder. Farewell."

[sub_resource type="Resource" id="ch_heart_offer"]
script = ExtResource("3_choice")
Text = "dlg.elder.heart.c_offer"
Goto = "heart_offer"
Condition = 1
ConditionArg = "quest.warband.heart"

[sub_resource type="Resource" id="ch_heart_active"]
script = ExtResource("3_choice")
Text = "dlg.elder.heart.c_active"
Goto = "heart_inprogress"
Condition = 2
ConditionArg = "quest.warband.heart"

[sub_resource type="Resource" id="ch_heart_thanks"]
script = ExtResource("3_choice")
Text = "dlg.elder.heart.c_thanks"
Goto = "heart_thanks"
Condition = 3
ConditionArg = "quest.warband.heart"

[sub_resource type="Resource" id="ch_heart_accept"]
script = ExtResource("3_choice")
Text = "dlg.elder.heart.c_accept"
Goto = "heart_accepted"
Effect = 1
EffectArg = "quest.warband.heart"

[sub_resource type="Resource" id="ch_heart_decline"]
script = ExtResource("3_choice")
Text = "dlg.elder.heart.c_decline"

[sub_resource type="Resource" id="ch_heart_accepted_bye"]
script = ExtResource("3_choice")
Text = "dlg.elder.heart.c_accepted_bye"

[sub_resource type="Resource" id="ch_heart_inprogress_bye"]
script = ExtResource("3_choice")
Text = "dlg.elder.heart.c_inprogress_bye"

[sub_resource type="Resource" id="ch_heart_thanks_bye"]
script = ExtResource("3_choice")
Text = "dlg.elder.heart.c_thanks_bye"

[sub_resource type="Resource" id="node_root"]
script = ExtResource("2_node")
Id = "root"
Text = "Well met, traveller. Our smith's forge runs cold — we've no iron to feed it."
Choices = Array[Resource]([SubResource("ch_root_friend"), SubResource("ch_root_pure"), SubResource("ch_root_marked"), SubResource("ch_heart_thanks"), SubResource("ch_heart_offer"), SubResource("ch_heart_active"), SubResource("ch_root_thanks"), SubResource("ch_root_offer"), SubResource("ch_root_active"), SubResource("ch_root_bye")])

[sub_resource type="Resource" id="node_offer"]
script = ExtResource("2_node")
Id = "offer"
Text = "Three lumps of iron ore from the northern hills would set us right. Will you help?"
Choices = Array[Resource]([SubResource("ch_offer_accept"), SubResource("ch_offer_decline")])

[sub_resource type="Resource" id="node_accepted"]
script = ExtResource("2_node")
Id = "accepted"
Text = "Bless you. The hills lie to the north — mind the goblins along the way."
Choices = Array[Resource]([SubResource("ch_accepted_bye")])

[sub_resource type="Resource" id="node_inprogress"]
script = ExtResource("2_node")
Id = "inprogress"
Text = "The forge still waits. Three lumps of ore — you'll find them in the hills to the north."
Choices = Array[Resource]([SubResource("ch_inprogress_bye")])

[sub_resource type="Resource" id="node_thanks"]
script = ExtResource("2_node")
Id = "thanks"
Text = "You brought the iron — the forge burns bright again. The village won't forget it."
Choices = Array[Resource]([SubResource("ch_thanks_done")])

[sub_resource type="Resource" id="node_friend"]
script = ExtResource("2_node")
Id = "friend"
Text = "Good to see you again, friend. The forge runs hot, thanks to you."
Choices = Array[Resource]([SubResource("ch_friend_bye")])

[sub_resource type="Resource" id="node_pure"]
script = ExtResource("2_node")
Id = "pure"
Text = "The elder meets your eyes and nods slowly. 'A steady soul — rarer than iron, these days. The Flame keeps you, traveller.'"
Choices = Array[Resource]([SubResource("ch_pure_bye")])

[sub_resource type="Resource" id="node_marked"]
script = ExtResource("2_node")
Id = "marked"
Text = "'There is an ember in your gaze I do not trust — ash where the light should be. I have seen it before, and it does not end gently. Tread carefully, traveller.'"
Choices = Array[Resource]([SubResource("ch_marked_embrace"), SubResource("ch_marked_deny")])

[sub_resource type="Resource" id="node_heart_offer"]
script = ExtResource("2_node")
Id = "heart_offer"
Text = "dlg.elder.heart.offer"
Choices = Array[Resource]([SubResource("ch_heart_accept"), SubResource("ch_heart_decline")])

[sub_resource type="Resource" id="node_heart_accepted"]
script = ExtResource("2_node")
Id = "heart_accepted"
Text = "dlg.elder.heart.accepted"
Choices = Array[Resource]([SubResource("ch_heart_accepted_bye")])

[sub_resource type="Resource" id="node_heart_inprogress"]
script = ExtResource("2_node")
Id = "heart_inprogress"
Text = "dlg.elder.heart.inprogress"
Choices = Array[Resource]([SubResource("ch_heart_inprogress_bye")])

[sub_resource type="Resource" id="node_heart_thanks"]
script = ExtResource("2_node")
Id = "heart_thanks"
Text = "dlg.elder.heart.thanks"
Choices = Array[Resource]([SubResource("ch_heart_thanks_bye")])

[resource]
script = ExtResource("1_dlg")
Id = "dialogue.elder"
SpeakerName = "Village Elder"
StartNodeId = "root"
Nodes = Array[Resource]([SubResource("node_root"), SubResource("node_offer"), SubResource("node_accepted"), SubResource("node_inprogress"), SubResource("node_thanks"), SubResource("node_friend"), SubResource("node_pure"), SubResource("node_marked"), SubResource("node_heart_offer"), SubResource("node_heart_accepted"), SubResource("node_heart_inprogress"), SubResource("node_heart_thanks")])
